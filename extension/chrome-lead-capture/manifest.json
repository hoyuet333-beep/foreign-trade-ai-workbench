{
  "manifest_version": 3,
  "name": "外贸 AI 工作台线索采集",
  "version": "0.1.0",
  "description": "从当前网页采集公司、联系人和来源页面，并发送到本地外贸 AI 工作台。",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:5173/*", "https://*/*", "http://*/*"],
  "action": {
    "default_title": "采集线索",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"]
    }
  ]
}
