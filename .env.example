# Optional: set this when you want the AI connector to call a real model.
# Without it, the workbench uses local template mode so the workflow remains usable.
VITE_OPENAI_API_KEY=

# OAuth connectors need user authorization before real inbox/site automation can run.
VITE_GMAIL_CLIENT_ID=
VITE_OUTLOOK_CLIENT_ID=
VITE_GITHUB_CLIENT_ID=
